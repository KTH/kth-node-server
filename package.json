{
  "name": "@kth/server",
  "version": "5.0.0-0",
  "description": "Module for initializing an Express server in a Node.js application.",
  "main": "index.js",
  "scripts": {
    "lint": "eslint --quiet",
    "lint-v": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "./build.sh",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KTH/kth-node-server"
  },
  "bugs": {
    "url": "https://github.com/KTH/kth-node-server/issues"
  },
  "homepage": "https://github.com/KTH/kth-node-server#readme",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "author": {
    "name": "KTH",
    "email": "infosys@kth.se",
    "url": "https://github.com/KTH"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@kth/eslint-config-kth": "^4.1.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4"
  },
  "prettier": {
    "arrowParens": "avoid",
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
